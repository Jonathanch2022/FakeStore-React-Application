# Auto normalize line endings for all text files
* text=auto

# C# source code
*.cs      text diff=csharp

# Solution and project files
*.sln     text eol=crlf
*.csproj  text eol=crlf
*.vbproj  text eol=crlf
*.fsproj  text eol=crlf
*.dbproj  text eol=crlf

# Common text formats
*.config  text eol=crlf
*.xml     text eol=crlf
*.json    text eol=crlf
*.yml     text eol=lf
*.yaml    text eol=lf
*.md      text eol=lf
*.txt     text

# Scripts
*.sh      text eol=lf
*.ps1     text eol=crlf
*.cmd     text eol=crlf
*.bat     text eol=crlf

# Web assets
*.html    text
*.css     text
*.js      text
*.ts      text
*.tsx     text
*.jsx     text

# Binary files (never convert line endings, don’t diff)
*.dll     binary
*.exe     binary
*.pdb     binary
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.zip     binary
*.tar     binary
*.gz      binary
*.7z      binary
*.pdf     binary
*.doc     binary
*.docx    binary
*.xls     binary
*.xlsx    binary
*.ppt     binary
*.pptx    binary
